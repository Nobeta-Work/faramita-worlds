      {
        "id": "setting-4",
        "type": "setting",
        "visible": {
          "public_visible": true,
          "player_visible": true,
          "unlock_condition": null
        },
        "category": "rule",
        "title": "魔法师称号体系",
        "content": "魔法师的称号分为魔导士、魔女见习生、魔女。其中魔女是具有稀世才华的人才能获得的最高阶称号，非常稀少而崇高。魔导士是底层。",
        "tags": [
          "等级制度",
          "魔法社会",
          "魔女",
          "魔导士"
        ]
      },
      {
        "id": "setting-5",
        "type": "setting",
        "visible": {
          "public_visible": true,
          "player_visible": true,
          "unlock_condition": null
        },
        "category": "faction",
        "title": "伪装成咖啡店的特务组织",
        "content": "一个表面上是咖啡店，实则为进行秘密活动的特务组织。成员多为男性，且很多人不会魔法。组织纪律严酷，失败或失去利用价值的成员会被处理掉。",
        "tags": [
          "秘密组织",
          "伪装",
          "咖啡店",
          "冷酷纪律"
        ]
      },
      {
        "id": "setting-6",
        "type": "setting",
        "visible": {
          "public_visible": true,
          "player_visible": true,
          "unlock_condition": null
        },
        "category": "location",
        "title": "水没的废墟城镇",
        "content": "一个被水部分淹没的废墟城镇。曾经的建筑已崩毁，被树木、苔藓覆盖，回归自然。除了伊蕾娜和艾姆妮西亚，已无人烟。环境凉爽，水声潺潺，有萤火虫飞舞。",
        "tags": [
          "废墟",
          "水没",
          "自然侵蚀",
          "无人居住",
          "秘境"
        ]
      },
      {
        "id": "setting-7",
        "type": "setting",
        "visible": {
          "public_visible": true,
          "player_visible": true,
          "unlock_condition": null
        },
        "category": "lore",
        "title": "毒苹果与睡美人",
        "content": "三百年前，魔女因嫉妒用毒苹果让森林中美丽少女陷入永眠。后来，有恋尸癖的王子亲吻少女遗体使其复活，但王子对活着的女人没兴趣而离开。此后森林定期长出毒苹果，注定被美丽少女吃下，并通过王子亲吻醒来。",
        "tags": [
          "传说",
          "毒苹果",
          "睡美人",
          "森林诅咒"
        ]
      },
      {
        "id": "setting-8",
        "type": "setting",
        "visible": {
          "public_visible": true,
          "player_visible": true,
          "unlock_condition": null
        },
        "category": "location",
        "title": "沉没水中的国家",
        "content": "一个位于森林深处、沉没在水中的独特国家。由漂浮在水面的尖塔和建筑组成，居民在水上生活。由族长领导，居民（如雅特丽）会使用魔法。主要食物来源是鱼类，但经过长期演化，当地鱼类含有毒素，只有适应了的原住民可以食用，外人食用会腹痛。该国过去因古都罗利亚的魔法而沉没。",
        "tags": [
          "水下城市",
          "魔法沉没",
          "独特生态",
          "与世隔绝"
        ]
      },
      {
        "id": "setting-9",
        "type": "setting",
        "visible": {
          "public_visible": true,
          "player_visible": true,
          "unlock_condition": null
        },
        "category": "location",
        "title": "邻近的王国",
        "content": "一个面临粮食危机的国家。国王因人口增长导致粮食不足，企图开垦邻近的森林区域，发现了水没街区（误以为是湖）并想捕捞渔获。曾与水没街区居民发生冲突。其国家过去可能曾使用魔法淹没水没街区的前身。",
        "tags": [
          "粮食危机",
          "扩张企图",
          "历史关联"
        ]
      },
      {
        "id": "setting-10",
        "type": "setting",
        "visible": {
          "public_visible": true,
          "player_visible": true,
          "unlock_condition": null
        },
        "category": "location",
        "title": "边境之阿尔贝德",
        "content": "拒绝魔法师入境的古老国家，建立于数百年前。由被邻国驱逐的非魔法师群体（过去称为“亚尼玛”）定居于一座旧堡垒遗迹而发展起来。国民普遍怨恨魔法师，采取禁止魔法师入境的政策。国土内建筑多为红砖砌成，景观普通。",
        "tags": [
          "排斥魔法师",
          "堡垒遗迹",
          "历史怨恨"
        ]
      },
      {
        "id": "setting-11",
        "type": "setting",
        "visible": {
          "public_visible": true,
          "player_visible": true,
          "unlock_condition": null
        },
        "category": "location",
        "title": "魔法师暂时收容所",
        "content": "位于边境之阿尔贝德的堡垒遗迹建筑，用于拘留非法入境的魔法师。外观有如城墙，爬满藤蔓。魔法师被关押在此，通过联系其国外亲友支付罚金后才会被驱逐出境，是阿尔贝德的重要收入来源。",
        "tags": [
          "拘留设施",
          "罚金勒索",
          "历史遗迹"
        ]
      },
      {
        "id": "setting-12",
        "type": "setting",
        "visible": {
          "public_visible": true,
          "player_visible": true,
          "unlock_condition": null
        },
        "category": "location",
        "title": "传说之剑",
        "content": "插在村庄底座上的双刃剑。传说只有“纯洁善良、不说谎话、以他人为优先、连虫也不舍得杀的杰出人士”才能拔出。曾被用作选拔勇者以对抗飞龙的仪式道具。实际上伊蕾娜和艾姆妮西亚都能拔出，传说可靠性存疑。",
        "tags": [
          "仪式道具",
          "勇者资格",
          "传说"
        ]
      },
      {
        "id": "setting-13",
        "type": "setting",
        "visible": {
          "public_visible": true,
          "player_visible": true,
          "unlock_condition": null
        },
        "category": "location",
        "title": "信仰之都伊斯特",
        "content": "艾姆妮西亚的故乡，一个封闭的国家。几乎断绝外交，采取“非国民同行不得入境”的政策，以防先进魔法技术外泄。离开该国者大多会丧失在伊斯特期间的记忆，极少数保留记忆者则会成为其国民并守口如瓶。艾姆妮西亚的失忆症可能与此地有关。",
        "tags": [
          "封闭国家",
          "记忆丧失",
          "魔法技术",
          "目的地"
        ]
      },
      {
        "id": "setting-14",
        "type": "setting",
        "visible": {
          "public_visible": true,
          "player_visible": true,
          "unlock_condition": null
        },
        "category": "item",
        "title": "镜水晶",
        "content": "信仰之都伊斯特特有的魔法技术产物。外观如水晶，能像镜子一样实时映照并传播远方的景象和声音。在这个国家被用作大众传媒工具，例如蔷薇魔女爱蜜莉雅通过镜水晶向全国发布公告和新闻。国民通过每月贡献魔力（类似纳税）来支持包括镜水晶在内的魔法技术运行。",
        "tags": [
          "通讯魔法",
          "国家技术",
          "魔力税系统"
        ]
      },
      {
        "id": "setting-15",
        "type": "setting",
        "visible": {
          "public_visible": true,
          "player_visible": true,
          "unlock_condition": null
        },
        "category": "rule",
        "title": "忘却归乡之刑",
        "content": "信仰之都伊斯特用于惩罚“大罪人”的特殊刑罚。对罪犯施加每天消除记忆的诅咒，然后将其流放国外。罪犯会本能地寻找故乡，最终回归伊斯特。刑罚持续到其归国并站上断头台的那一刻才解除。其目的在于让罪犯在不断的相遇与离别中积累幸福或希望的回忆，最终在意识到所有旅程都只是通往死刑的过程时，在极度的后悔与绝望中被处决。",
        "tags": [
          "残酷刑罚",
          "记忆诅咒",
          "心理折磨",
          "死刑前置"
        ]
      },
      {
        "id": "setting-16",
        "type": "setting",
        "visible": {
          "public_visible": true,
          "player_visible": true,
          "unlock_condition": null
        },
        "category": "rule",
        "title": "信仰之都伊斯特的魔法社会",
        "content": "一个所有国民都是魔法师的国家。魔法技术高度发达，如镜水晶和魔力吸收利用系统。国家运行依赖于一种“魔力税”制度，即国民每月贡献自身魔力，由国家集中用于魔法技术开发和公共福祉。这里魔女地位特殊，曾是国家的“财产”。",
        "tags": [
          "全员魔法师",
          "魔力税",
          "技术导向",
          "魔女地位"
        ]
      },
      {
        "id": "setting-17",
        "type": "setting",
        "visible": {
          "public_visible": true,
          "player_visible": true,
          "unlock_condition": null
        },
        "category": "faction",
        "title": "正统骑士团",
        "content": "信仰之都伊斯特的治安与行政组织，负责宫殿杂务、镜水晶操作、事件调查、要人保护等。成员多为魔法师，但像艾姆妮西亚这样魔法能力不足者也可担任杂务。",
        "tags": [
          "治安组织",
          "魔法师",
          "杂务",
          "内部维护"
        ]
      }
    ],
